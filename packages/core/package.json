{
  "$schema": "https://json.schemastore.org/package",
  "name": "@congcn/cesium-kit-core",
  "version": "0.0.0",
  "description": "cesium-kit 核心包",
  "keywords": [],
  "author": "CongYao",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/congcn/cesium-kit.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/congcn/cesium-kit#readme",
  "bugs": {
    "url": "https://github.com/congcn/cesium-kit/issues"
  },
  "private": false,
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {},
  "peerDependencies": {
    "cesium": "^1.140.0"
  },
  "devDependencies": {
    "cesium": "^1.140.0"
  }
}
